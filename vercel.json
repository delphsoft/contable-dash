{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/arca-cron.js": { "maxDuration": 60 },
    "api/arca-sync.js": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/arca-cron", "schedule": "0 6 * * *" }
  ]
}
